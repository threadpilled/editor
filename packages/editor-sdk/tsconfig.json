{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist",
    "paths": {
      "@threadpilled/embed": ["../../../libs/embed/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/adapters/react.tsx", "src/adapters/solidjs.tsx"]
}
