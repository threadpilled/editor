{
  "name": "@threadpilled/editor-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/editor-app && npx vite --port 4830",
    "build": "cd packages/editor-sdk && npx tsc && cd ../editor-app && npx vite build",
    "typecheck": "npx tsc --noEmit -p packages/editor-sdk/tsconfig.json"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "vite": "6.3.5"
  }
}
